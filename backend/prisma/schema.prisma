generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Currency {
  code          String    @id @db.VarChar(3)
  name          String    @db.VarChar(100)
  symbol        String    @db.VarChar(10)
  decimalPlaces Int       @map("decimal_places")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  countries Country[]
  users     User[]

  @@map("currencies")
}

model Country {
  iso2         String   @id @db.VarChar(2)
  iso3         String   @unique @db.VarChar(3)
  name         String   @db.VarChar(100)
  flagUrl      String   @map("flag_url") @db.VarChar(255)
  currencyCode String   @map("currency_code") @db.VarChar(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  currency     Currency       @relation(fields: [currencyCode], references: [code])
  users        User[]
  gameCountries GameCountry[]

  @@index([currencyCode])
  @@map("countries")
}

model GameType {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(50)
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  games Game[]

  @@map("game_types")
}

model Game {
  id           String   @id @default(uuid()) @db.Uuid
  externalId   String   @unique @map("external_id") @db.VarChar(100)
  slug         String   @unique @db.VarChar(100)
  title        String   @db.VarChar(255)
  providerName String   @map("provider_name") @db.VarChar(100)
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  startUrl     String?  @map("start_url") @db.VarChar(500)
  gameTypeId   String   @map("game_type_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  gameType          GameType           @relation(fields: [gameTypeId], references: [id])
  gameCountries     GameCountry[]
  userFavoriteGames UserFavoriteGame[]
  spinHistory       SpinHistory[]

  @@index([title])
  @@index([providerName], map: "idx_games_provider_name")
  @@index([gameTypeId], map: "idx_games_game_type_id")
  @@map("games")
}

model GameCountry {
  gameId      String   @map("game_id") @db.Uuid
  countryIso2 String   @map("country_iso2") @db.VarChar(2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  game    Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryIso2], references: [iso2])

  @@id([gameId, countryIso2])
  @@index([countryIso2], map: "idx_game_countries_country_iso2")
  @@map("game_countries")
}

model User {
  id                    String   @id @default(uuid()) @db.Uuid
  email                 String   @unique @db.VarChar(255)
  passwordHash          String   @map("password_hash") @db.VarChar(255)
  balance               Decimal  @db.Decimal(12, 2)
  countryIso2           String   @map("country_iso2") @db.VarChar(2)
  preferredCurrencyCode String   @map("preferred_currency_code") @db.VarChar(3)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  country           Country            @relation(fields: [countryIso2], references: [iso2])
  preferredCurrency Currency           @relation(fields: [preferredCurrencyCode], references: [code])
  favoriteGames     UserFavoriteGame[]
  spinHistory       SpinHistory[]

  @@index([countryIso2], map: "idx_users_country_iso2")
  @@map("users")
}

model UserFavoriteGame {
  userId    String   @map("user_id") @db.Uuid
  gameId    String   @map("game_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
  @@index([gameId], map: "idx_user_favorite_games_game_id")
  @@map("user_favorite_games")
}

model SpinHistory {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  gameId        String   @map("game_id") @db.Uuid
  reelResultKey String   @map("reel_result_key") @db.VarChar(100)
  amount        Decimal  @map("amount") @db.Decimal(12, 2)
  balanceBefore Decimal  @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal  @map("balance_after") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  @@index([userId, createdAt(sort: Desc)], map: "idx_spin_history_user_created_at")
  @@index([gameId], map: "idx_spin_history_game_id")
  @@map("spin_history")
}
